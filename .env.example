# ─────────────────────────────────────────────────────────────
# MisanRD — Variables de entorno del FRONTEND (Vite)
# Copia este archivo a `.env` y complétalo con tus valores.
# Solo variables con prefijo VITE_ se exponen al navegador.
# NUNCA pongas aquí la service_role key de Supabase.
# ─────────────────────────────────────────────────────────────

# URL de tu proyecto Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co

# Clave pública "anon" de Supabase (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Nombre público de la app (opcional)
VITE_APP_NAME=MisanRD

# URL base pública del sitio desplegado (para links del portal / recibos).
# Ej. GitHub Pages project page:
VITE_PUBLIC_URL=https://TU-USUARIO.github.io/MisanRD/
